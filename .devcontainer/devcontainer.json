{
  "name": "C++ Quant Platform",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "cmake.useCMakePresets": "always",
        "cmake.configureOnOpen": false,
        "cmake.buildDirectory": "${workspaceFolder}/build/${buildPresetName}",
        "C_Cpp.default.cppStandard": "c++20",
        "C_Cpp.default.compileCommands": "${workspaceFolder}/build/debug/compile_commands.json"
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "cmake --preset debug && cmake --build --preset debug --parallel && ctest --preset debug --output-on-failure",
  "containerEnv": {
    "CC": "gcc",
    "CXX": "g++"
  }
}
